datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Passenger {
  id                  String        @id @default(uuid()) @db.Uuid
  name                String
  email               String        @unique
  phone               String
  preferred_ride_type String?       @map("preferred_ride_type")
  created_at          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  password_hash       String        @default("") @map("password_hash")
  is_verified         Boolean       @default(false) @map("is_verified")
  ride_requests       RideRequest[]

  @@map("passengers")
}

model RideRequest {
  id                String    @id @default(uuid()) @db.Uuid
  passenger_id      String    @map("passenger_id") @db.Uuid
  ride_type         String    @map("ride_type")
  pickup_latitude   Float     @map("pickup_latitude")
  pickup_longitude  Float     @map("pickup_longitude")
  pickup_name       String    @map("pickup_name")
  dropoff_latitude  Float     @map("dropoff_latitude")
  dropoff_longitude Float     @map("dropoff_longitude")
  dropoff_name      String    @map("dropoff_name")
  fare              Float     @map("fare")
  status            String    @map("status")
  created_at        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  passenger         Passenger @relation(fields: [passenger_id], references: [id])

  @@map("ride_requests")
}
