/// Trip schema defining passenger ride requests, telemetry paths, and driver matching status tracking in trip_db.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Ride {
  id               String   @id @default(uuid()) @db.Uuid
  passengerId      String   @map("passenger_id") @db.Uuid
  passengerName    String?  @map("passenger_name")
  rideType         String   @map("ride_type")
  pickupLatitude   Float    @map("pickup_latitude")
  pickupLongitude  Float    @map("pickup_longitude")
  pickupName       String   @map("pickup_name")
  dropoffLatitude  Float    @map("dropoff_latitude")
  dropoffLongitude Float    @map("dropoff_longitude")
  dropoffName      String   @map("dropoff_name")
  fare             Float
  status           String
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  completedAt      DateTime? @map("completed_at") @db.Timestamptz

  driverId         String?  @map("driver_id")
  driverName       String?  @map("driver_name")
  driverRating     String?  @map("driver_rating")
  vehicleType      String?  @map("vehicle_type")
  plateNumber      String?  @map("plate_number")

  @@map("rides")
}
